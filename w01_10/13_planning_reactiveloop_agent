def calculator(expr:str):
    try:
        return str(eval(expr))
    except Exception as e:
        return f"Error: {e}"
 
kb = {
    "LangChain": "A framework for building LLM-powered agents.",
    "RAG": "Retrieval-Augmented Generation, combining retrieval + generation.",
    "CrewAI": "A framework for multi-agent orchestration."
}
def lookup(term:str):
    return kb.get(term, f"No entry for {term}")
 
tools = [
    Tool(name="Calculator", func=calculator, description="Do math calculations."),
    Tool(name="Lookup", func=lookup, description="Look up terms in knowledge base."),
]


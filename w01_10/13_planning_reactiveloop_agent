#Planning Agent
#Planning = break request into subtasks first, then execute.

from langchain_core.prompts import PromptTemplate

plan_prompt = PromptTemplate.from_template("""
You are a planning agent. Break the following request into subtasks before answering:
{task}
Return plan as:
1. Subtask A
2. Subtask B
""")


def planning_agent(task: str):
    prompt_value = plan_prompt.invoke({"task": task})
    response = llm.invoke(prompt_value)
    plan = response.content if hasattr(response, "content") else str(response)
    print("Plan:")
    print(plan)

    # crude execution: match keyword to tool
    answer_parts = []
    if "Calculate" in plan or "Compute" in plan:
        answer_parts.append("Calc: " + calculator("15*4"))
    if "Research" in plan or "Explain" in plan or "Lookup" in plan:
        answer_parts.append("Lookup: " + lookup("LangChain"))
    return "\n".join(answer_parts)


print("\n--- Planning Agent ---")
